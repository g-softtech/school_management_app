generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 1 — Core Entities
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  classes          Class[]
  students         Student[]
  feeStructures    FeeStructure[]
  invoices         Invoice[]
  payments         Payment[]
  grades           Grade[]
  attendanceSheets AttendanceSheet[]
  subjects         Subject[]
  academicSessions AcademicSession[]
  timetableSlots   TimetableSlot[]
  assessments      Assessment[]
  // Phase 5 — tenant-scoped
  messages         Message[]
  notifications    Notification[]
  lessonNotes      LessonNote[]
  assignments      Assignment[]
  weeklyPlanners   WeeklyPlanner[]
  auditLogs        AuditLog[]
  creditLedgers    CreditLedger[]
  paymentIntents   PaymentIntent[]
  admissions       AdmissionApplication[]
}

model User {
  id                   String    @id @default(cuid())
  tenantId             String
  tenant               Tenant    @relation(fields: [tenantId], references: [id])

  name                 String
  email                String
  password             String
  role                 String    @default("student")
  phone                String?
  qualification        String?
  isActive             Boolean   @default(true)

  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  lastLogin            DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  studentProfile       Student?       @relation("UserToStudent")
  parentOf             Student[]      @relation("ParentToStudent")
  taughtSubjects       Subject[]      @relation("TeacherSubjects")
  timetableSlots       TimetableSlot[] @relation("TeacherSlots")

  @@unique([tenantId, email])
}

model Student {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  userId          String   @unique
  user            User     @relation("UserToStudent", fields: [userId], references: [id], onDelete: Cascade)

  admissionNumber String
  classId         String?
  class           Class?   @relation(fields: [classId], references: [id])

  parentId        String?
  parent          User?    @relation("ParentToStudent", fields: [parentId], references: [id])

  gender          String
  dateOfBirth     DateTime
  phone           String?
  address         String?
  photo           String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices          Invoice[]
  grades            Grade[]
  attendanceRecords AttendanceRecord[]
  assessmentScores  AssessmentScore[]
  submissions       Submission[]

  @@unique([tenantId, admissionNumber])
}

model Class {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  name         String
  section      String?
  academicYear String
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students         Student[]
  invoices         Invoice[]
  feeStructures    FeeStructure[]
  attendanceSheets AttendanceSheet[]
  grades           Grade[]
  subjects         Subject[]
  timetableSlots   TimetableSlot[]
  assessments      Assessment[]
  lessonNotes      LessonNote[]
  assignments      Assignment[]
  weeklyPlanners   WeeklyPlanner[]

  @@unique([tenantId, name, section, academicYear])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3 — Financial Models
// ─────────────────────────────────────────────────────────────────────────────

// FeeStructure: defines the fee catalogue for a given term/session.
// Maps to: backend/src/models/FeeStructure.js
model FeeStructure {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])

  name        String
  feeType     String  // tuition | exam | sports | library | development | transport | hostel | pta | uniform | feeding | ict | other
  amount      Float
  scope       String  @default("all_classes") // all_classes | specific_class | specific_student
  session     String
  term        String  @default("all")         // first | second | third | all
  frequency   String  @default("per_term")    // per_term | per_session | one_time
  description String?
  isActive    Boolean @default(true)

  allowInstallment Boolean @default(false)
  minInstallment   Float?

  classId     String?
  class       Class?   @relation(fields: [classId], references: [id])
  studentId   String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceLineItems InvoiceLineItem[]

  @@index([tenantId, session, term])
  @@index([tenantId, classId, session])
}

// Invoice: a student's full bill for a specific term/session.
// Maps to: backend/src/models/StudentBill.js
model Invoice {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classId String
  class   Class   @relation(fields: [classId], references: [id])

  session      String
  term         String  // first | second | third
  status       String  @default("unpaid") // unpaid | partial | paid | overpaid
  isLocked     Boolean @default(false)
  revision     Int     @default(0)

  totalAmount  Float @default(0)
  totalPaid    Float @default(0)
  totalBalance Float @default(0)
  carryOver    Float @default(0)

  // Self-referential: carry-over amount from a prior invoice
  carryOverSourceInvoiceId String?
  carryOverAmountSnapshot  Float?  @default(0)
  discountNote             String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lineItems   InvoiceLineItem[]
  payments    Payment[]
  adjustments BillAdjustment[]

  @@unique([tenantId, studentId, session, term])
  @@index([tenantId, classId, session, term])
  @@index([tenantId, status])
}

// InvoiceLineItem: individual fee line inside an Invoice.
// Maps to: the embedded billLineSchema array inside StudentBill.js
model InvoiceLineItem {
  id       String @id @default(cuid())
  tenantId String

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])

  feeName   String
  feeType   String
  amount    Float
  discount  Float  @default(0)
  netAmount Float
  paid      Float  @default(0)
  balance   Float  @default(0)
  status    String @default("unpaid") // unpaid | partial | paid | waived

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
}

// BillAdjustment: discount, waiver, scholarship, or penalty on a line item.
// Maps to: backend/src/models/BillAdjustment.js
model BillAdjustment {
  id       String @id @default(cuid())
  tenantId String

  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  lineItemId      String  // soft FK to InvoiceLineItem.id
  type            String  // discount | waiver | penalty | scholarship | transfer_in | transfer_out
  amount          Float
  reason          String
  transferGroupId String?
  status          String  @default("applied") // applied | reversed

  approvedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([invoiceId, status])
  @@index([invoiceId, lineItemId, status])
}

// Payment: a real money transaction linked to an Invoice.
// Maps to: backend/src/models/Payment.js
model Payment {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  studentId String
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  amount        Float
  feeType       String  // tuition | exam | ... | multiple | other
  term          String  // first | second | third
  session       String
  status        String  @default("pending") // pending | paid | failed | cancelled | awaiting_approval | reversed
  paymentMethod String  @default("paystack") // paystack | flutterwave | cash | bank_transfer | pos | cheque | wallet

  // Unique transaction references (nullable = sparse equivalent in PostgreSQL)
  reference      String? @unique
  glReference    String?
  receiptNumber  String? @unique
  transactionRef String?

  bankName    String?
  accountName String?
  paystackData    Json?
  receiptSnapshot Json?
  notes           String?

  requiresApproval Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?
  rejectedReason   String?
  recordedById     String?
  paidAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, studentId, term, session])
  @@index([tenantId, status])
  @@index([invoiceId])
  @@index([reference])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3 — Academic Models
// ─────────────────────────────────────────────────────────────────────────────

// Grade: per-student, per-subject academic result for a given term.
// Maps to: backend/src/models/Result.js
model Grade {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classId String
  class   Class   @relation(fields: [classId], references: [id])

  // Now a real FK to the Subject model added in Phase 4
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  subjectName String?  // denormalised snapshot — avoids a join on report cards

  term    String // first | second | third
  session String

  ca     Float  // continuous assessment 0–40
  exam   Float  // exam score 0–60
  total  Float  // computed: ca + exam
  grade  String? // A1 … F9
  remark String? // Excellent, Very Good, Pass, Fail …

  uploadedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, studentId, subjectId, term, session])
  @@index([tenantId, classId, term, session])
  @@index([tenantId, studentId])
}

// AttendanceSheet: one register per class per calendar day.
// Maps to: the parent attendanceSchema in backend/src/models/Attendance.js
model AttendanceSheet {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  classId      String
  class        Class    @relation(fields: [classId], references: [id])

  date         DateTime // always normalised to UTC midnight
  term         String   // first | second | third
  session      String
  recordedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records AttendanceRecord[]

  @@unique([tenantId, classId, date, term, session])
  @@index([tenantId, classId, term, session])
}

// AttendanceRecord: one row per student per AttendanceSheet.
// Maps to: the embedded recordSchema array inside Attendance.js
model AttendanceRecord {
  id       String @id @default(cuid())
  tenantId String

  sheetId String
  sheet   AttendanceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  status String  // present | absent | late
  notes  String?

  createdAt DateTime @default(now())

  @@unique([sheetId, studentId])
  @@index([tenantId, studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 4 — Academic Infrastructure
// ─────────────────────────────────────────────────────────────────────────────

// Subject: a course offered to a specific class, optionally assigned to a teacher.
// Maps to: backend/src/models/Subject.js
// Wires up Grade.subjectId (pre-staged in Phase 3).
model Subject {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])

  name        String
  code        String   // e.g. MATH, ENG, BIO — unique per tenant
  description String?
  isActive    Boolean  @default(true)

  classId     String
  class       Class    @relation(fields: [classId], references: [id])

  // Optional default teacher for this subject in this class
  teacherId   String?
  teacher     User?    @relation("TeacherSubjects", fields: [teacherId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  grades         Grade[]
  timetableSlots TimetableSlot[]
  assessments    Assessment[]
  lessonNotes    LessonNote[]
  assignments    Assignment[]
  weeklyPlanners WeeklyPlanner[]

  @@unique([tenantId, code, classId])     // same code can exist in different classes
  @@index([tenantId, classId])
  @@index([tenantId, teacherId])
}

// AcademicSession: the school year container, with embedded term date windows.
// Maps to: backend/src/models/AcademicSession.js
model AcademicSession {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  name      String         // e.g. "2025/2026"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean        @default(false)
  isActive  Boolean        @default(true)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  terms AcademicTerm[]

  @@index([tenantId, isCurrent])
  @@index([tenantId, name])
}

// AcademicTerm: one of up to three terms inside an AcademicSession.
// Maps to: the embedded termSchema array inside AcademicSession.js
model AcademicTerm {
  id        String @id @default(cuid())
  tenantId  String

  sessionId String
  session   AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  name      String   // first | second | third
  startDate DateTime?
  endDate   DateTime?
  isActive  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, name])            // no duplicate term names within a session
  @@index([tenantId, sessionId])
}

// TimetableSlot: one period row in the weekly schedule matrix.
// The original Timetable model had an embedded `periods` array — we promote
// each period to its own row for queryability ("who teaches what on Monday?").
// Maps to: backend/src/models/Timetable.js (periodSchema + timetableSchema)
model TimetableSlot {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  teacherId String?
  teacher   User?    @relation("TeacherSlots", fields: [teacherId], references: [id])

  academicSession String           // e.g. "2025/2026" — string key for fast filtering
  term            String           // first | second | third
  day             String           // Monday | Tuesday | Wednesday | Thursday | Friday
  period          Int              // period number within the day, e.g. 1, 2, 3 ...
  startTime       String           // "08:00" — stored as HH:mm string
  endTime         String           // "08:45"
  label           String?          // e.g. "Break", "Assembly" for non-subject slots

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Prevents the same class from having two subjects in the same period on the same day
  @@unique([tenantId, classId, academicSession, term, day, period])
  // Prevents a teacher from being double-booked at the same period across any class
  @@unique([tenantId, teacherId, academicSession, term, day, period])
  @@index([tenantId, classId, academicSession, term])
  @@index([tenantId, teacherId, academicSession, term])
}

// Assessment: a graded milestone event (e.g. Midterm, Final Exam, CA Test 1).
// Maps to: no direct MongoDB equivalent — new relational entity.
model Assessment {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  title     String           // e.g. "Midterm Exam", "CA Test 1", "Final Exam"
  type      String           // ca | exam | quiz | project | practical
  term      String           // first | second | third
  session   String
  maxScore  Float            // maximum achievable marks
  weight    Float            @default(1.0) // percentage weight toward final Grade total
  dueDate   DateTime?
  isPublished Boolean        @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scores AssessmentScore[]

  @@index([tenantId, classId, term, session])
  @@index([tenantId, subjectId, term, session])
}

// AssessmentScore: one student's score on a specific Assessment.
model AssessmentScore {
  id           String @id @default(cuid())
  tenantId     String

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])

  score        Float
  remarks      String?
  gradedById   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt


  @@unique([assessmentId, studentId])    // one score per student per assessment
  @@index([tenantId, studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 5A — Tenant-Scoped Communication & Collaboration
// ─────────────────────────────────────────────────────────────────────────────

// Message: direct or broadcast messaging between users within a school.
// Maps to: backend/src/models/Message.js
model Message {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  senderId   String
  receiverId String?  // null when isBroadcast = true

  subject     String?
  content     String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  isBroadcast Boolean   @default(false)
  targetRole  String?   // admin | teacher | student | parent (for broadcasts)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, receiverId, isRead])
  @@index([tenantId, senderId])
}

// Notification: in-app notification bell entries per user per school.
// Maps to: backend/src/models/Notification.js
model Notification {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  userId   String
  title    String
  message  String
  type     String  @default("general") // result | payment | assignment | announcement | general | system_alert
  isRead   Boolean @default(false)
  link     String? // optional deep-link URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, userId, isRead])
  @@index([tenantId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 5B — Tenant-Scoped Teaching & Learning
// ─────────────────────────────────────────────────────────────────────────────

// LessonNote: teacher-authored lesson plans/notes per subject, class, and week.
// Maps to: backend/src/models/LessonNote.js
model LessonNote {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  teacherId  String
  classId    String
  class      Class   @relation(fields: [classId], references: [id])
  subjectId  String
  subject    Subject @relation(fields: [subjectId], references: [id])

  topic      String
  week       Int     // 1–20
  term       String  // first | second | third
  session    String
  content    String?
  fileUrl    String?
  fileName   String?
  isPublished Boolean @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, classId, subjectId, term, session])
  @@index([tenantId, teacherId])
}

// Assignment: teacher-issued graded task for a class + subject.
// Maps to: backend/src/models/Assignment.js
model Assignment {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  teacherId  String
  classId    String
  class      Class   @relation(fields: [classId], references: [id])
  subjectId  String
  subject    Subject @relation(fields: [subjectId], references: [id])

  title      String
  question   String
  fileUrl    String?
  fileName   String?
  dueDate    DateTime
  maxScore   Float
  term       String   // first | second | third
  session    String
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  submissions Submission[]

  @@index([tenantId, classId, subjectId])
  @@index([tenantId, teacherId])
}

// Submission: a student's response to an Assignment.
// Maps to: backend/src/models/Submission.js
model Submission {
  id           String  @id @default(cuid())
  tenantId     String

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId    String
  student      Student    @relation(fields: [studentId], references: [id])

  answer       String?
  fileUrl      String?
  fileName     String?
  submittedAt  DateTime  @default(now())
  score        Float?
  feedback     String?
  gradedAt     DateTime?
  gradedById   String?
  status       String    @default("submitted") // submitted | graded | returned

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([assignmentId, studentId])  // one submission per student per assignment
  @@index([tenantId, studentId])
}

// WeeklyPlanner: teacher's weekly curriculum progress tracker.
// Maps to: backend/src/models/WeeklyPlanner.js
model WeeklyPlanner {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  teacherId  String
  classId    String
  class      Class   @relation(fields: [classId], references: [id])
  subjectId  String
  subject    Subject @relation(fields: [subjectId], references: [id])

  week              Int      // 1–20
  term              String   // first | second | third
  session           String
  topicsCovered     String[] // PostgreSQL native text array
  notes             String?
  completionStatus  String   @default("planned") // planned | in_progress | completed

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, teacherId, classId, subjectId, week, term, session])
  @@index([tenantId, classId, subjectId, term, session])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 5C — Tenant-Scoped Financial Ledger & Operations
// ─────────────────────────────────────────────────────────────────────────────

// AuditLog: HTTP-level operation trail, scoped per tenant.
// Maps to: backend/src/models/Auditlog.js
model AuditLog {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  userId     String?
  userRole   String?
  action     String
  method     String  // GET | POST | PATCH | DELETE
  resource   String  // e.g. "/api/students"
  statusCode Int?
  ip         String?
  userAgent  String?
  body       Json?   // request body snapshot (PII should be stripped before save)

  createdAt  DateTime @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
}

// CreditLedger: wallet balance record per student/user within a school.
// Maps to: backend/src/models/CreditLedger.js
model CreditLedger {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  userId   String
  balance  Float   @default(0)
  status   String  @default("active") // active | frozen | closed | under_review
  rebuildInProgress Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CreditTransaction[]

  @@unique([tenantId, userId])   // one ledger per user per tenant
}

// CreditTransaction: immutable double-entry ledger row.
// Maps to: backend/src/models/CreditTransaction.js
// Note: immutability enforced at application layer in controllers.
model CreditTransaction {
  id       String @id @default(cuid())
  tenantId String

  ledgerId         String
  ledger           CreditLedger @relation(fields: [ledgerId], references: [id])

  glReference      String
  sourceEventId    String?  // upstream event that triggered this entry
  sourceEventType  String?  // payment | waiver | refund | manual_adjustment | wallet_merge
  relatedInvoiceId String?  // soft FK to Invoice.id
  relatedLineItemId String? // soft FK to InvoiceLineItem.id

  amount        Float   // positive = deposit, negative = withdrawal
  type          String  // overpayment | waiver_reversal | allocation | refund | correction
  balanceAfter  Float
  notes         String?

  createdAt DateTime @default(now())

  // Idempotency: no duplicate processing of the same upstream event
  @@unique([sourceEventType, sourceEventId])
  @@index([ledgerId])
  @@index([glReference])
}

// PaymentIntent: pre-authorization record before gateway confirmation.
// Maps to: backend/src/models/PaymentIntent.js
model PaymentIntent {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  userId         String
  studentId      String
  invoiceId      String  // FK to Invoice.id

  walletAmount   Float  @default(0)
  paystackAmount Float
  feeType        String
  allocations    Json   @default("[]")  // [{itemId, amount}] serialized
  term           String
  session        String
  status         String @default("pending") // pending | completed | failed
  reference      String @unique

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([reference])
}

// AdmissionApplication: prospective student enquiry form.
// Maps to: backend/src/models/AdmissionApplication.js
model AdmissionApplication {
  id           String  @id @default(cuid())
  tenantId     String
  tenant       Tenant  @relation(fields: [tenantId], references: [id])

  fullName     String
  dateOfBirth  DateTime?
  gender       String?   // male | female | other
  applyingFor  String
  parentName   String
  email        String
  phone        String
  address      String?
  notes        String?
  status       String    @default("pending") // pending | reviewing | accepted | rejected
  adminNotes   String?
  reviewedById String?
  reviewedAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, email])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 5D — Global Infrastructure (Platform-Level, No tenantId)
//
// These models are shared across ALL tenants and run at the platform layer.
// They track the health, observability, and resilience of the system itself
// rather than any school's data.
// ─────────────────────────────────────────────────────────────────────────────

// OutboxEvent: transactional outbox pattern for reliable event delivery.
// Maps to: backend/src/models/OutboxEvent.js
model OutboxEvent {
  id       String @id @default(cuid())

  type     String // e.g. REBUILD_BILL
  invoiceId String  // soft FK to Invoice.id (no cascade — platform-level)
  eventKey String @unique // deduplication key: e.g. "REBUILD_BILL:{id}:{revision}"
  status   String @default("pending") // pending | processing | retry_wait | completed | dead_letter

  attempts       Int      @default(0)
  nextRetryAt    DateTime @default(now())
  leaseExpiresAt DateTime?
  workerId       String?

  lastAttemptAt DateTime?
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  errorReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replayHistory OutboxReplayHistory[]

  @@index([status, nextRetryAt])
  @@index([status, leaseExpiresAt])
}

// OutboxReplayHistory: audit trail of retries and DLQ replays.
// Maps to: the embedded replayHistory array inside OutboxEvent.js
model OutboxReplayHistory {
  id           String @id @default(cuid())

  eventId      String
  event        OutboxEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  type         String    // retry | dlq_replay
  adminId      String?   // soft FK to User.id
  timestamp    DateTime  @default(now())

  @@index([eventId])
}

// SystemAlert: active infrastructure alert records.
// Maps to: backend/src/models/SystemAlert.js
model SystemAlert {
  id          String @id @default(cuid())

  alertKey    String
  fingerprint String
  severity    String // warning | critical | escalated_critical
  source      String @default("financial_outbox")
  status      String @default("active") // active | resolved
  message     String

  firstTriggeredAt        DateTime  @default(now())
  lastSentAt              DateTime?
  resolvedAt              DateTime?
  pendingResolutionSince  DateTime?
  triggerCount            Int       @default(1)
  currentValue            Float?
  peakValue               Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// SreStatus: current SRE finite-state machine status (singleton-style record).
// Maps to: backend/src/models/SreStatus.js
model SreStatus {
  id       String @id @default(cuid())

  sreState String @default("NORMAL") // NORMAL | PENDING_FREEZE | DEGRADED | FROZEN | EMERGENCY_BYPASS
  freezeReason          String?
  freezeStartedAt       DateTime?
  pendingFreezeStartedAt DateTime?
  recoveryStartedAt     DateTime?
  errorBudgetUsed       Float @default(0)
  errorBudgetLimit      Float @default(0)

  breakGlassActive    Boolean  @default(false)
  breakGlassExpiresAt DateTime?
  breakGlassReason    String?
  breakGlassScope     String[] // PostgreSQL text array
  breakGlassAdminId   String?

  currentTransitionId  String?
  previousTransitionId String?
  currentFastBurn      Float @default(0)
  currentMediumBurn    Float @default(0)
  currentSlowBurn      Float @default(0)
  currentAcceleration  Float @default(0)
  evaluationVersion    String @default("v1.0")
  lastEvaluatedAt      DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// SreTransitionEvent: immutable log of every SRE state machine transition.
// Maps to: backend/src/models/SreTransitionEvent.js
model SreTransitionEvent {
  id           String @id @default(cuid())

  transitionId String @unique
  fromState    String
  toState      String
  triggerSource String  // FAST_BURN | MEDIUM_BURN | BREAK_GLASS

  burnRateFast           Float
  burnRateMedium         Float
  burnRateSlow           Float
  errorAcceleration      Float
  normalizedAcceleration Float

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// WebhookEvent: idempotency guard for inbound payment gateway webhooks.
// Maps to: backend/src/models/WebhookEvent.js
model WebhookEvent {
  id        String @id @default(cuid())

  eventId   String @unique  // provider event ID used for idempotency
  provider  String @default("paystack") // paystack | flutterwave | system
  status    String @default("processing") // processing | processed | failed
  eventType String?
  payload   Json   @default("{}")
  errorReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// WorkerNode: heartbeat registry of active background worker processes.
// Maps to: backend/src/models/WorkerNode.js
// Note: MongoDB TTL index (expireAfterSeconds: 180) is replicated here as a
// scheduled cleanup job pattern — PostgreSQL does not have native TTL indexes.
model WorkerNode {
  id         String   @id @default(cuid())
  workerId   String   @unique
  hostname   String
  pid        Int
  lastSeenAt DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([lastSeenAt])   // used by the stale-worker cleanup job
}

// AdminActionLock: distributed mutex for long-running admin operations.
// Maps to: backend/src/models/AdminActionLock.js
// Note: MongoDB TTL index replaced by a scheduled cleanup job — same pattern as WorkerNode.
model AdminActionLock {
  id        String @id @default(cuid())

  actionKey String @unique
  lockedById String
  status    String @default("running") // running | completed
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])  // used by the lock-expiry cleanup job
}

// ScanJob: credit-ledger drift scan execution record.
// Maps to: backend/src/models/ScanJob.js
model ScanJob {
  id        String @id @default(cuid())

  status    String @default("pending") // pending | processing | completed | failed
  processedCount Int @default(0)
  totalExpected  Int @default(0)
  anomaliesFound Int @default(0)
  anomalies      Json @default("[]")  // [{userId, ledgerId, currentBalance, calculatedBalance, driftAmount, driftLevel}]
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  errorReason    String?
  scanTimestamp  DateTime @default(now())

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ChaosRunReport: result record from a chaos engineering test suite run.
// Maps to: backend/src/models/ChaosRunReport.js
model ChaosRunReport {
  id       String @id @default(cuid())

  testName    String  // SNIPER | CONCURRENCY | ROLLBACK
  batchId     String
  status      String  // PASS | FAIL

  totalJobs      Int?
  completedJobs  Int?
  failedJobs     Int?
  workerKills    Int    @default(0)
  executionTimeMs Int

  metrics    Json?    // custom test-specific metrics
  anomalies  String[] // error messages from the run

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([batchId])
  certifications SystemCertification[]
}

// SystemCertification: immutable pass/fail badge for a full chaos test suite.
// Maps to: backend/src/models/SystemCertification.js
model SystemCertification {
  id      String @id @default(cuid())

  version String @unique // e.g. "v1.0.0" or commit hash
  batchId String
  status  String // PASS | FAIL

  runId   String  // FK to one representative ChaosRunReport
  run     ChaosRunReport @relation(fields: [runId], references: [id])

  maxJobLossRate            Float?
  maxDuplicateExecution     Float?
  workerFailureToleranceLevel Float?
  concurrencyCeiling        Float?
  transactionIntegrity      String?

  certifiedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId])
}

// OperationalMetricsDaily: one-row-per-day throughput snapshot for the outbox worker.
// Maps to: backend/src/models/OperationalMetricsDaily.js
model OperationalMetricsDaily {
  id            String @id @default(cuid())

  date          String @unique  // YYYY-MM-DD (UTC) — natural unique key for upsert
  throughput    Int    @default(0)
  dlqCount      Int    @default(0)
  activeWorkers Int    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
